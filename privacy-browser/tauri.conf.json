{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Onyx",
  "version": "1.0.0",
  "identifier": "com.onyx.browser",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Onyx",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self' data: https: http: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https: http: blob:; connect-src 'self' https: http: wss: ws:; font-src 'self' data: https:; media-src 'self' data: https: http:; frame-src 'self' https: http:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "dialog": {
      "open": true,
      "save": true
    },
    "fs": {
      "scope": ["$APPDATA/onyx/*", "$DOWNLOAD/*"],
      "read": true,
      "write": true
    },
    "opener": {
      "open": true
    }
  }
}